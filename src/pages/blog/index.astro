---
import Base from "@/layouts/Base.astro";
import PostList from "@/components/PostList.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "@/data/site.config";

const posts = (await getCollection("post", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(posts.flatMap((post) => post.data.tags || []))].sort();

const blogJsonLd = {
  "@type": "Blog",
  name: `${siteConfig.name} Blog`,
  description: "Articles on AI engineering, system design, RAG systems, and building production software.",
  url: `${siteConfig.url}/blog`,
  author: { "@type": "Person", name: siteConfig.author, url: siteConfig.url },
  blogPost: posts.slice(0, 10).map(post => ({
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.pubDate.toISOString(),
    url: `${siteConfig.url}/blog/${post.id}`,
    author: { "@type": "Person", name: siteConfig.author },
  })),
};
---

<Base title="Blog" description="In-depth articles on AI agents, RAG systems, system design, LangChain, microservices, and building production AI applications. By Mehul Jariwala." jsonLd={blogJsonLd}>
  <h1 class="text-3xl font-bold text-zinc-900 dark:text-zinc-100 mb-4">Blog</h1>
  <p class="text-zinc-600 dark:text-zinc-400 mb-8">
    Thoughts on AI, engineering, and building software.
  </p>

  {
    allTags.length > 0 && (
      <div class="mb-8 flex flex-wrap gap-2">
        {allTags.map((tag) => (
          <a
            href={`/tags/${tag}`}
            class="rounded-full border border-zinc-200 px-3 py-1 text-sm text-zinc-600 hover:border-accent hover:text-accent dark:border-zinc-700 dark:text-zinc-400"
          >
            #{tag}
          </a>
        ))}
      </div>
    )
  }

  {posts.length > 0 ? (
    <PostList posts={posts} />
  ) : (
    <p class="text-zinc-500 dark:text-zinc-400">No posts yet.</p>
  )}
</Base>
