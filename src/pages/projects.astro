  version: "1.8.0",
  description: "React document viewer component — render PDF, Word, Excel, PowerPoint, Markdown, images, video, CSV and 20+ file types with annotations, text search, dark mode, drag-and-drop, thumbnails, zoom and i18n.",
  npm: "https://www.npmjs.com/package/@iamjariwala/react-doc-viewer",
  github: "https://github.com/mehuljariwala/react-doc-viewer",
  tags: ["react", "typescript", "pdf-viewer", "document-viewer", "open-source"],
};

