---
import Base from "@/layouts/Base.astro";
import PostList from "@/components/PostList.astro";
import ImageCanvas from "@/components/ImageCanvas.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "@/data/site.config";

const posts = (await getCollection("post", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const homeJsonLd = [
  {
    "@type": "Person",
    "@id": `${siteConfig.url}/#person`,
    name: "Mehul Jariwala",
    givenName: "Mehul",
    familyName: "Jariwala",
    url: siteConfig.url,
    jobTitle: "AI/ML Engineer & Full-Stack Consultant",
    description: siteConfig.description,
    knowsAbout: ["Artificial Intelligence", "Machine Learning", "LLM Agents", "RAG Systems", "LangChain", "React", "Next.js", "Node.js", "Python", "TypeScript", "AWS", "GCP", "Kubernetes", "Docker"],
    worksFor: { "@type": "Organization", name: "FasterOutcomes" },
    alumniOf: [
      { "@type": "Organization", name: "IBM" },
      { "@type": "CollegeOrUniversity", name: "Jain University" },
    ],
    sameAs: [
      siteConfig.links.linkedin,
      siteConfig.links.github,
      siteConfig.links.twitter,
      siteConfig.links.medium,
    ],
  },
  {
    "@type": "WebSite",
    "@id": `${siteConfig.url}/#website`,
    url: siteConfig.url,
    name: siteConfig.name,
    description: siteConfig.description,
    publisher: { "@id": `${siteConfig.url}/#person` },
    inLanguage: "en-US",
  },
  {
    "@type": "ProfilePage",
    mainEntity: { "@id": `${siteConfig.url}/#person` },
    dateCreated: "2024-01-01",
    dateModified: new Date().toISOString().split("T")[0],
  },
];
---

<Base jsonLd={homeJsonLd}>
  <section class="mb-16">
    <h1 class="text-3xl font-bold text-zinc-900 dark:text-zinc-100">
      Hi, I'm <span class="text-accent">Mehul</span>
    </h1>
    <p class="mt-4 text-lg text-zinc-600 dark:text-zinc-400">
      Full-Stack Engineer & AI/ML Specialist with 8+ years of experience shipping production software.
      I build web apps, AI agents, RAG systems, and scalable platforms.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href={siteConfig.links.github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-zinc-600 hover:text-accent dark:text-zinc-400"
      >
        GitHub
      </a>
      <span class="text-zinc-300 dark:text-zinc-600">/</span>
      <a
        href={siteConfig.links.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-zinc-600 hover:text-accent dark:text-zinc-400"
      >
        LinkedIn
      </a>
      <span class="text-zinc-300 dark:text-zinc-600">/</span>
      <a
        href={siteConfig.links.medium}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-zinc-600 hover:text-accent dark:text-zinc-400"
      >
        Medium
      </a>
      <span class="text-zinc-300 dark:text-zinc-600">/</span>
      <a
        href={siteConfig.links.twitter}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-zinc-600 hover:text-accent dark:text-zinc-400"
      >
        Twitter
      </a>
      <span class="text-zinc-300 dark:text-zinc-600">/</span>
      <a
        href={siteConfig.links.email}
        class="text-sm text-zinc-600 hover:text-accent dark:text-zinc-400"
      >
        Email
      </a>
    </div>
  </section>

  <section class="mb-16">
    <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-6">Companies I've Worked With</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {[
        { name: "IBM", logo: "/logos/ibm.svg" },
        { name: "Amazon", logo: "/logos/amazon.svg" },
        { name: "Tesco", logo: "/logos/tesco.svg" },
        { name: "Walmart", logo: "/logos/walmart.svg" },
        { name: "Flipkart", logo: "/logos/flipkart.svg" },
        { name: "T-Mobile", logo: "/logos/tmobile.svg" },
        { name: "Tata Neu", logo: "/logos/tataneu.svg" },
        { name: "Publicis Sapient", logo: "/logos/publicissapient.svg" },
      ].map((company) => (
        <div class="flex items-center justify-center rounded-lg border border-zinc-200 bg-white p-4 dark:border-zinc-700 dark:bg-zinc-800">
          <img
            src={company.logo}
            alt={company.name}
            class="h-10 w-auto object-contain"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </section>

  <section class="mb-16">
    <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-6">Appreciation for Good Work</h2>
    <ImageCanvas images={[
      { src: "/appreciation/1.png", alt: "Gold Medal — Jain University" },
      { src: "/appreciation/2.png", alt: "QuickerHQ — \"Our hero @Mehul!\"" },
      { src: "/appreciation/3.png", alt: "Houck — \"Great addition to the team!!\"" },
      { src: "/appreciation/4.png", alt: "Lottie — \"Absolute pleasure to work with you\"" },
      { src: "/appreciation/5.png", alt: "Natasha — \"I know you'll smash it\"" },
      { src: "/appreciation/6.png", alt: "Benjamin — \"Excellent community member\"" },
      { src: "/appreciation/7.png", alt: "Grace — \"Great work Mehul\"" },
      { src: "/appreciation/8.png", alt: "Tesco — Rewards and Recognition" },
      { src: "/appreciation/9.png", alt: "Tesco — \"No one tries harder for customers\"" },
      { src: "/appreciation/10.png", alt: "IBM — Recognition & BluePoints Award" },
      { src: "/appreciation/11.png", alt: "Nikita — \"Deeply appreciating your contribution\"" },
      { src: "/appreciation/12.png", alt: "Publicis Sapient — React 101 Completion" },
      { src: "/appreciation/13.png", alt: "Rishi — \"You are a mini hanuman\" — FasterOutcomes" },
      { src: "/appreciation/14.png", alt: "Archana — \"Absolutely killed it with Knowledge UI\"" },
      { src: "/appreciation/15.png", alt: "Sam Torres — \"You're awesome. Keep up the great work\"" },
      { src: "/appreciation/16.png", alt: "Maria — \"Awesomeee, this is great\"" },
      { src: "/appreciation/17.png", alt: "Grace Dixie — \"Great work Mehul\"" },
      { src: "/appreciation/18.png", alt: "Alex Hamer — \"Well done\"" },
    ]} />
  </section>

  <section class="mb-16">
    <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-6">Open Source</h2>
    <a
      href="https://www.npmjs.com/package/@iamjariwala/react-doc-viewer"
      target="_blank"
      rel="noopener noreferrer"
      class="block rounded-lg border border-zinc-200 p-5 transition-colors hover:border-accent dark:border-zinc-700 dark:hover:border-accent group"
    >
      <div class="flex items-start justify-between gap-4">
        <div>
          <div class="flex items-center gap-2 flex-wrap mb-1">
            <h3 class="text-lg font-semibold text-zinc-900 group-hover:text-accent dark:text-zinc-100">
              @iamjariwala/react-doc-viewer
            </h3>
            <span class="rounded-full bg-accent/10 px-2 py-0.5 text-xs font-medium text-accent">v1.8.0</span>
          </div>
          <p class="text-sm text-zinc-600 dark:text-zinc-400 mt-1">
            React document viewer component — render PDF, Word, Excel, PowerPoint, Markdown, images, video, CSV and 20+ file types with annotations, text search, dark mode, drag-and-drop, thumbnails, zoom and i18n.
          </p>
          <div class="mt-3 flex flex-wrap gap-2">
            {["react", "pdf-viewer", "document-viewer", "typescript", "open-source"].map(tag => (
              <span class="rounded-full border border-zinc-200 dark:border-zinc-700 px-2 py-0.5 text-xs text-zinc-500 dark:text-zinc-400">{tag}</span>
            ))}
          </div>
        </div>
        <div class="shrink-0 text-zinc-400 dark:text-zinc-500">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
        </div>
      </div>
      <div class="mt-3 flex items-center gap-4 text-xs text-zinc-500 dark:text-zinc-400">
        <span class="flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          GitHub
        </span>
        <span class="flex items-center gap-1">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M0 0v24h24V0H0zm13.52 18.6c-.29.05-.4-.13-.4-.28v-2.1c0-.71-.25-1.18-.52-1.41 1.7-.19 3.48-.83 3.48-3.77 0-.83-.3-1.51-.79-2.05.08-.19.34-.97-.08-2.01 0 0-.64-.21-2.1.78-.61-.17-1.27-.26-1.92-.26-.65 0-1.31.09-1.92.26-1.46-.99-2.1-.78-2.1-.78-.42 1.04-.16 1.82-.08 2.01-.49.54-.79 1.22-.79 2.05 0 2.93 1.78 3.58 3.47 3.77-.22.19-.41.53-.48 1.03-.43.19-1.52.53-2.2-.63-.14-.23-.57-.79-1.17-.78-.64.01-.26.37.01.51.32.18.69.85.77 1.07.15.42.64 1.22 2.53.88v1.43c0 .15-.1.33-.39.28A8 8 0 1113.52 18.6z"/></svg>
          npm
        </span>
        <span>Apache-2.0</span>
        <span>20+ file types</span>
      </div>
    </a>
  </section>

  <section>
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">Recent Posts</h2>
      <a href="/blog" class="text-sm text-accent hover:text-accent-hover">
        View all &rarr;
      </a>
    </div>
    {posts.length > 0 ? (
      <PostList posts={posts} />
    ) : (
      <p class="text-zinc-500 dark:text-zinc-400">No posts yet.</p>
    )}
  </section>
</Base>
